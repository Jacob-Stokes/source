# Define one entry per Calibre library.
# Format: LIBRARY_<NAME>=/path/to/library/base
# The container expects <base>/books/metadata.db and <base>/config/app.db
# Optionally set LIBRARY_<NAME>_URL so external apps can discover the library's web UI

LIBRARY_FICTION=/data/fiction
LIBRARY_FICTION_URL=https://fiction.example.com
LIBRARY_NONFICTION=/data/nonfiction
LIBRARY_NONFICTION_URL=https://nonfiction.example.com
# LIBRARY_POETRY=/data/poetry
# LIBRARY_POETRY_URL=https://poetry.example.com
