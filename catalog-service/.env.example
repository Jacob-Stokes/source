# catalog-service — service inventory + REST API
# Auth: Cloudflare Access at the edge + per-caller X-API-Key (managed in UI).
# Keys are minted via the dashboard, hashed at rest in KEYS_FILE.

# Beszel PocketBase superuser for reading container + system state.
# Create via: docker exec beszel /beszel superuser upsert <email> <password>
BESZEL_URL=http://beszel:8090
BESZEL_CATALOG_EMAIL=catalog@beszel.example
BESZEL_CATALOG_PASSWORD=changeme

# Cloudflare API token (read-only — Access apps + their policies).
# Token needs: Zone:Read on your zone + Account:Access:Apps:Read.
CF_ACCOUNT_ID=changeme
CF_API_TOKEN=changeme

# Comma-separated emails allowed to manage API keys via the dashboard.
# Matched against the Cf-Access-Authenticated-User-Email header that
# Cloudflare Access stamps on authenticated browser requests.
ADMIN_EMAILS=you@example.com

# How stale joined data can be (ms). Default 60s.
CACHE_TTL_MS=60000

# Mount /root/docker-services (or equivalent) here for catalog.yml hints.
SERVICES_ROOT=/services

# cloudflared config to parse for hostname→port mappings.
CF_CONFIG_PATH=/cf/config.yml

# Persistent volume for the hashed API keys store.
KEYS_FILE=/data/keys.json
