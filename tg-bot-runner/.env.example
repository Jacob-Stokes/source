# thesys-data-bot — Telegram bot for daily helper queries

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=changeme

# Comma-separated numeric Telegram user IDs allowed to message the bot.
# Get your ID via @userinfobot in Telegram.
TELEGRAM_ALLOWED_USER_IDS=123456789

# Claude Code OAuth token. Obtain via `claude setup-token` on a
# subscribed machine. The Agent SDK reads this and routes through
# subscription billing.
CLAUDE_CODE_OAUTH_TOKEN=changeme

# Which Claude model to use. Haiku is cheap + fast; bump to Sonnet
# if the bot is routinely failing to reason through tool chains.
MODEL=claude-haiku-4-5

# How many recent turns to carry as context on each message.
HISTORY_LIMIT=20

# SQLite file. Mount a volume here so history survives restarts.
DB_PATH=/data/chat.db

# Where the Claude Code skills live. Install script drops them here.
SKILLS_DIR=/root/.claude/skills

# Optional: override the system prompt. Leave unset for the default.
# SYSTEM_PROMPT=
